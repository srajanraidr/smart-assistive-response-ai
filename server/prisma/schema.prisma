generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  OPERATOR
}

enum IncidentStatus {
  NEW
  REVIEW
  ASSIGNED
  EN_ROUTE
  ON_SCENE
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmergencyCall {
  id                   Int      @id @default(autoincrement())
  callerPhone          String?
  transcript           String
  transcriptConfidence Float?
  audioFile            String?
  language             String?
  createdAt            DateTime @default(now())

  incidents Incident[]
}

model Incident {
  id Int @id @default(autoincrement())

  title         String
  description   String?
  emergencyType String
  priority      Priority
  location      String?
  aiConfidence  Float?

  recommendedDepartment String?
  riskLevel             String?
  keywords              Json?
  requiresHumanReview   Boolean @default(true)

  emergencyCallId Int?
  emergencyCall   EmergencyCall? @relation(fields: [emergencyCallId], references: [id])

  status IncidentStatus @default(NEW)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
