generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  OPERATOR
}

enum IncidentStatus {
  NEW
  REVIEW
  ASSIGNED
  EN_ROUTE
  ON_SCENE
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  role         UserRole

  assignedIncidents Incident[] @relation("IncidentAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmergencyCall {
  id                   Int      @id @default(autoincrement())
  callerPhone          String?
  transcript           String
  transcriptConfidence Float?
  audioFile            String?
  language             String?
  createdAt            DateTime @default(now())

  incidents Incident[]
}

model Incident {
  id Int @id @default(autoincrement())

  title         String
  description   String?
  emergencyType String
  priority      Priority
  location      String?
  aiConfidence  Float?

  recommendedDepartment String?
  riskLevel             String?
  keywords              Json?
  requiresHumanReview   Boolean @default(true)

  emergencyCallId Int?
  emergencyCall   EmergencyCall? @relation(fields: [emergencyCallId], references: [id])

  // Dispatcher assignment
  assignedToId Int?
  assignedTo   User? @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  status IncidentStatus @default(NEW)

  history IncidentHistory[]

  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncidentHistory {
  id         Int      @id @default(autoincrement())

  incidentId Int
  incident   Incident @relation(fields: [incidentId], references: [id])

  action String @default("STATUS_CHANGED")        // e.g. CREATED, STATUS_CHANGED, ASSIGNED
  oldStatus  String?
  newStatus  String?
  message    String?

  changedAt  DateTime @default(now())
}
